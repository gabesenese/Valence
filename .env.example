# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://valence:valence_dev@localhost:5432/valence_db?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string_min_64_chars
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── AI Provider ──────────────────────────────────────────────────────────────
# mock | groq | anthropic. groq powers existing extraction; anthropic (via the
# Vercel AI Gateway) is the premium provider for Finance Copilot.
AI_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Vercel AI Gateway (preferred for Copilot — gives fallbacks + cost observability)
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
# Internal flag to expose Finance Copilot features before GA (true|false)
FEATURE_FINANCE_COPILOT=false

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIALS=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_EXECUTIVE=
# Valence Copilot add-on — create a recurring Stripe price and paste its id here.
# Its amount MUST match ADDONS.valence_copilot.price in shared/src/addons.ts ($49/mo).
STRIPE_PRICE_AI_COPILOT=

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Create a project at sentry.io and paste the DSN here
SENTRY_DSN=
# Client DSN (add to client/.env.local as VITE_SENTRY_DSN=...)
VITE_SENTRY_DSN=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Window and per-key request budget. Requests are keyed per authenticated user
# (RATE_LIMIT_AUTHED_MAX), falling back to client IP for anonymous traffic
# (RATE_LIMIT_MAX_REQUESTS). Values below match the server defaults.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_AUTHED_MAX=3000

# ─── Document Storage ─────────────────────────────────────────────────────────
# When set, document uploads go to Vercel Blob (durable). Unset -> local disk
# under server/uploads/documents (dev only; not persistent on serverless).
BLOB_READ_WRITE_TOKEN=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Create a project at resend.com and paste the API key here
# Without this, emails are logged to console (development only)
RESEND_API_KEY=
FROM_EMAIL=noreply@valenceos.ca
APP_URL=http://localhost:5173

# ─── Platform Admin ───────────────────────────────────────────────────────────
# Secret required to access /admin. Keep this out of source control.
PLATFORM_ADMIN_SECRET=
OWNER_EMAIL=

# ─── Integrations ─────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting stored OAuth tokens at rest (any long random string).
INTEGRATIONS_ENC_KEY=
# QuickBooks Online (Intuit). Use the Development (sandbox) keys first.
# Register the redirect URI below in your Intuit app under "Redirect URIs".
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3001/api/integrations/quickbooks/callback
QBO_ENVIRONMENT=sandbox
