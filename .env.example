# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://valence:valence_dev@localhost:5432/valence_db?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string_min_64_chars
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── AI Provider (future) ─────────────────────────────────────────────────────
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
