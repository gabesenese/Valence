{
  "name": "@valence/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "vercel-build": "npx prisma generate && if [ \"$VERCEL_ENV\" = \"production\" ]; then npx prisma migrate deploy; fi",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-tester": "tsx src/scripts/seed-tester.ts",
    "db:seed-thin": "tsx src/scripts/seed-thin-account.ts",
    "db:backfill-revenue": "tsx src/scripts/backfill-revenue.ts",
    "db:reconcile-orphan-leases": "tsx src/scripts/reconcile-orphan-leases.ts",
    "db:reconcile-orphan-tasks": "tsx src/scripts/reconcile-orphan-tasks.ts",
    "db:reconcile-orphan-alerts": "tsx src/scripts/reconcile-orphan-alerts.ts",
    "db:audit-document-refs": "tsx src/scripts/audit-document-refs.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.56.0",
    "@valence/shared": "*",
    "@vercel/blob": "^2.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "groq-sdk": "^1.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "read-excel-file": "^9.2.0",
    "resend": "^6.12.4",
    "speakeasy": "^2.0.0",
    "stripe": "^22.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
