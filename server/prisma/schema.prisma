generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ANALYST
  VIEWER
}

enum Plan {
  ESSENTIALS
  PROFESSIONAL
  EXECUTIVE
}

enum UsageType {
  AI_ANALYSIS
  CONTRACT_PROCESSING
  IMPACT_SIMULATION
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  INDUSTRIAL
  RETAIL
  OFFICE
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  UNDER_RENOVATION
  DISPOSED
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  PENDING
  TERMINATED
  RENEWED
}

enum LeaseType {
  GROSS
  NET
  MODIFIED_GROSS
  PERCENTAGE
  GROUND
}

enum RenewalRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FinancialRecordType {
  REVENUE
  EXPENSE
  ADJUSTMENT
  REFUND
  DEPOSIT
}

enum FinancialRecordStatus {
  PENDING
  RECONCILED
  FLAGGED
  DISPUTED
  VOID
}

enum AlertType {
  LEASE_EXPIRATION
  RENEWAL_RISK
  PAYMENT_ANOMALY
  DATA_MISSING
  FINANCIAL_DISCREPANCY
  OCCUPANCY_CHANGE
  COMPLIANCE_FLAG
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  DISMISSED
  SUPPRESSED   // legacy
}

enum RenewalStage {
  NOT_STARTED
  CONTACTED
  NEGOTIATING
  DRAFT_SENT
  LEGAL_REVIEW
  SCHEDULED_RENEWAL
  SIGNED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InsightCategory {
  FINANCIAL
  OPERATIONAL
  LEASE
  RISK
  FORECAST
}

enum CrmStatus {
  ACTIVE
  AT_RISK
  HIGH_VALUE
  CHURNED
}

enum ContactLogType {
  CALL
  EMAIL
  MEETING
  NOTE
  SITE_VISIT
}

enum DocumentType {
  LEASE
  INSURANCE
  INSPECTION
  PERMIT
  AMENDMENT
  NOTICE
  FINANCIAL
  OTHER
}

enum AutomationTrigger {
  LEASE_DAYS_REMAINING
  PAYMENT_OVERDUE_DAYS
  OCCUPANCY_BELOW
  RISK_SCORE_ABOVE
}

enum AutomationAction {
  CREATE_TASK
  NOTIFY_ASSIGNEE
  ESCALATE_ALERT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  role             UserRole  @default(ANALYST)
  plan             Plan      @default(ESSENTIALS)
  trialEndsAt      DateTime? @map("trial_ends_at")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  mfaSecret        String?   @map("mfa_secret")
  mfaEnabled       Boolean   @default(false) @map("mfa_enabled")
  isActive         Boolean   @default(true) @map("is_active")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  alerts             Alert[]         @relation("AlertCreatedBy")
  assignedAlerts     Alert[]         @relation("AlertAssignee")
  acknowledgedAlerts Alert[]         @relation("AlertAcknowledgedBy")
  dismissedAlerts    Alert[]         @relation("AlertDismissedBy")
  resolvedAlerts     Alert[]         @relation("AlertResolvedBy")
  alertActivities    AlertActivity[] @relation("AlertActivityActor")
  insights           Insight[]       @relation("InsightCreatedBy")
  ownedLeases        Lease[]         @relation("LeaseOwner")
  leaseActivities    LeaseActivity[] @relation("LeaseActivityActor")
  leaseNotes         LeaseNote[]     @relation("LeaseNoteAuthor")
  assignedTasks      Task[]          @relation("TaskAssignee")
  createdTasks       Task[]          @relation("TaskCreatedBy")
  completedTasks     Task[]          @relation("TaskCompletedBy")
  managedTenants     Tenant[]        @relation("TenantManager")
  contactLogs        ContactLog[]    @relation("ContactLogAuthor")
  uploadedDocuments  Document[]      @relation("DocumentUploader")
  createdRules       AutomationRule[] @relation("RuleCreatedBy")
  usageRecords       UsageRecord[]
  auditLogs          AuditLog[]
  ownedProperties    Property[]      @relation("PropertyOwner")
  ownedTenants       Tenant[]        @relation("TenantOwner")
  sentInvites        Invite[]        @relation("InvitedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Invite {
  id          String    @id @default(uuid())
  email       String
  role        UserRole  @default(ANALYST)
  token       String    @unique
  invitedById String    @map("invited_by_id")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([token])
  @@index([email])
  @@map("invites")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

model Property {
  id           String         @id @default(uuid())
  name         String
  code         String
  type         PropertyType
  status       PropertyStatus @default(ACTIVE)
  address      String
  city         String
  state        String
  zipCode      String         @map("zip_code")
  country      String         @default("US")
  totalUnits   Int            @map("total_units")
  totalSqft    Decimal        @map("total_sqft") @db.Decimal(12, 2)
  yearBuilt    Int?           @map("year_built")
  purchaseDate DateTime?      @map("purchase_date")
  purchasePrice Decimal?      @map("purchase_price") @db.Decimal(15, 2)
  currentValue  Decimal?      @map("current_value") @db.Decimal(15, 2)
  metadata     Json?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  ownerId      String?        @map("owner_id")

  owner            User?             @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  leases           Lease[]
  financialRecords FinancialRecord[]
  alerts           Alert[]
  insights         Insight[]
  tasks            Task[]
  documents        Document[]

  @@index([status])
  @@index([type])
  @@index([city, state])
  @@index([ownerId])
  @@map("properties")
}

model Tenant {
  id                 String     @id @default(uuid())
  name               String
  email              String?
  phone              String?
  company            String?
  taxId              String?    @map("tax_id")
  creditScore        Int?       @map("credit_score")
  notes              String?
  isActive           Boolean    @default(true) @map("is_active")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  ownerId            String?    @map("owner_id")

  // CRM fields
  assignedManagerId  String?    @map("assigned_manager_id")
  renewalProbability Int?       @map("renewal_probability")
  lastContactAt      DateTime?  @map("last_contact_at")
  crmStatus          CrmStatus  @default(ACTIVE) @map("crm_status")

  owner           User?        @relation("TenantOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  leases          Lease[]
  assignedManager User?        @relation("TenantManager", fields: [assignedManagerId], references: [id])
  contactLogs     ContactLog[]
  documents       Document[]

  @@index([name])
  @@index([email])
  @@index([ownerId])
  @@index([assignedManagerId])
  @@index([crmStatus])
  @@map("tenants")
}

model Lease {
  id               String      @id @default(uuid())
  leaseNumber      String      @unique @map("lease_number")
  propertyId       String      @map("property_id")
  tenantId         String      @map("tenant_id")
  unitNumber       String?     @map("unit_number")
  type             LeaseType   @default(GROSS)
  status           LeaseStatus @default(ACTIVE)
  renewalRisk      RenewalRisk @default(LOW) @map("renewal_risk")
  startDate        DateTime    @map("start_date")
  endDate          DateTime    @map("end_date")
  renewalDate      DateTime?   @map("renewal_date")
  baseRent         Decimal     @map("base_rent") @db.Decimal(12, 2)
  rentEscalation   Decimal     @default(0) @map("rent_escalation") @db.Decimal(5, 4)
  securityDeposit  Decimal?    @map("security_deposit") @db.Decimal(12, 2)
  sqft             Decimal?    @db.Decimal(10, 2)
  terms              Json?
  notes              String?
  terminatedAt       DateTime?    @map("terminated_at")
  terminationReason  String?      @map("termination_reason")
  ownerUserId        String?      @map("owner_user_id")
  renewalStage       RenewalStage @default(NOT_STARTED) @map("renewal_stage")
  renewalScheduledAt DateTime?    @map("renewal_scheduled_at")
  lastContactedAt    DateTime?    @map("last_contacted_at")
  snoozedUntil       DateTime?    @map("snoozed_until")
  reviewedAt         DateTime?    @map("reviewed_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  property         Property          @relation(fields: [propertyId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  owner            User?             @relation("LeaseOwner", fields: [ownerUserId], references: [id])
  financialRecords FinancialRecord[]
  alerts           Alert[]
  activities       LeaseActivity[]
  leaseNotes       LeaseNote[]
  tasks            Task[]
  contactLogs      ContactLog[]
  documents        Document[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
  @@index([endDate])
  @@index([renewalRisk])
  @@index([ownerUserId])
  @@index([renewalStage])
  @@index([snoozedUntil])
  @@map("leases")
}

model FinancialRecord {
  id           String                @id @default(uuid())
  propertyId   String                @map("property_id")
  leaseId      String?               @map("lease_id")
  type         FinancialRecordType
  status       FinancialRecordStatus @default(PENDING)
  amount       Decimal               @db.Decimal(15, 2)
  currency     String                @default("USD")
  periodStart  DateTime              @map("period_start")
  periodEnd    DateTime              @map("period_end")
  dueDate      DateTime?             @map("due_date")
  paidDate     DateTime?             @map("paid_date")
  description  String?
  category     String?
  referenceId  String?               @map("reference_id")
  discrepancy  Decimal?              @db.Decimal(15, 2)
  notes        String?
  metadata     Json?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])
  lease    Lease?   @relation(fields: [leaseId], references: [id])

  @@index([propertyId])
  @@index([leaseId])
  @@index([type])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([dueDate])
  @@map("financial_records")
}

model Alert {
  id          String        @id @default(uuid())
  type        AlertType
  severity    AlertSeverity
  status      AlertStatus   @default(OPEN)
  title       String
  description String
  propertyId  String?       @map("property_id")
  leaseId     String?       @map("lease_id")
  createdById String?       @map("created_by_id")
  resolvedAt  DateTime?     @map("resolved_at")
  resolvedBy  String?       @map("resolved_by")
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  assigneeUserId   String?   @map("assignee_user_id")
  resolutionNote   String?   @map("resolution_note")

  acknowledgedAt   DateTime? @map("acknowledged_at")
  acknowledgedById String?   @map("acknowledged_by_id")
  dismissedAt      DateTime? @map("dismissed_at")
  dismissedById    String?   @map("dismissed_by_id")

  property          Property?       @relation(fields: [propertyId], references: [id])
  lease             Lease?          @relation(fields: [leaseId], references: [id])
  createdBy         User?           @relation("AlertCreatedBy", fields: [createdById], references: [id])
  assignee          User?           @relation("AlertAssignee", fields: [assigneeUserId], references: [id])
  acknowledgedByUser User?          @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  dismissedByUser   User?           @relation("AlertDismissedBy", fields: [dismissedById], references: [id])
  resolvedByUser    User?           @relation("AlertResolvedBy", fields: [resolvedBy], references: [id])
  activities        AlertActivity[]
  tasks             Task[]

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([propertyId])
  @@index([leaseId])
  @@index([createdAt])
  @@map("alerts")
}

model AlertActivity {
  id          String   @id @default(uuid())
  alertId     String   @map("alert_id")
  action      String   // CREATED, PROGRESSED, RESOLVED, DISMISSED, ASSIGNED, SCAN_CREATED
  actorUserId String?  @map("actor_user_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  actor User? @relation("AlertActivityActor", fields: [actorUserId], references: [id])

  @@index([alertId])
  @@index([createdAt])
  @@map("alert_activities")
}

model JobLock {
  id          String   @id
  lockedAt    DateTime @map("locked_at")
  lockedUntil DateTime @map("locked_until")

  @@map("job_locks")
}

model LeaseActivity {
  id          String   @id @default(uuid())
  leaseId     String   @map("lease_id")
  actorUserId String?  @map("actor_user_id")
  actionType  String   @map("action_type")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  actor User? @relation("LeaseActivityActor", fields: [actorUserId], references: [id])

  @@index([leaseId])
  @@index([createdAt])
  @@map("lease_activities")
}

model LeaseNote {
  id           String   @id @default(uuid())
  leaseId      String   @map("lease_id")
  authorUserId String?  @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  lease  Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  author User? @relation("LeaseNoteAuthor", fields: [authorUserId], references: [id])

  @@index([leaseId])
  @@map("lease_notes")
}

model Insight {
  id          String          @id @default(uuid())
  category    InsightCategory
  title       String
  summary     String
  body        Json
  propertyId  String?         @map("property_id")
  createdById String?         @map("created_by_id")
  confidence  Decimal?        @db.Decimal(4, 3)
  validUntil  DateTime?       @map("valid_until")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  property  Property? @relation(fields: [propertyId], references: [id])
  createdBy User?     @relation("InsightCreatedBy", fields: [createdById], references: [id])

  @@index([category])
  @@index([propertyId])
  @@index([createdAt])
  @@map("insights")
}

model Task {
  id             String     @id @default(uuid())
  title          String
  description    String?
  status         TaskStatus @default(OPEN)

  alertId        String?    @map("alert_id")
  leaseId        String?    @map("lease_id")
  propertyId     String?    @map("property_id")

  assigneeUserId String?    @map("assignee_user_id")
  createdById    String?    @map("created_by_id")

  completedAt    DateTime?  @map("completed_at")
  completedById  String?    @map("completed_by_id")
  completionNote String?    @map("completion_note")

  dueAt          DateTime?  @map("due_at")

  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  alert       Alert?    @relation(fields: [alertId],    references: [id], onDelete: SetNull)
  lease       Lease?    @relation(fields: [leaseId],    references: [id], onDelete: SetNull)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignee    User?     @relation("TaskAssignee",   fields: [assigneeUserId], references: [id])
  createdBy   User?     @relation("TaskCreatedBy",  fields: [createdById],    references: [id])
  completedBy User?     @relation("TaskCompletedBy", fields: [completedById], references: [id])

  @@index([status])
  @@index([alertId])
  @@index([leaseId])
  @@index([propertyId])
  @@index([assigneeUserId])
  @@index([createdAt])
  @@map("tasks")
}

// ─── CRM / Communication ──────────────────────────────────────────────────────

model ContactLog {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  leaseId   String?        @map("lease_id")
  type      ContactLogType
  body      String
  userId    String?        @map("user_id")
  createdAt DateTime       @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease?  @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  user   User?   @relation("ContactLogAuthor", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([leaseId])
  @@index([createdAt])
  @@map("contact_logs")
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Document {
  id           String       @id @default(uuid())
  name         String
  originalName String       @map("original_name")
  type         DocumentType @default(OTHER)
  mimeType     String       @map("mime_type")
  size         Int
  path         String
  propertyId   String?      @map("property_id")
  leaseId      String?      @map("lease_id")
  tenantId     String?      @map("tenant_id")
  uploadedById String?      @map("uploaded_by_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  lease      Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  uploadedBy User?     @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([propertyId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([type])
  @@map("documents")
}

// ─── Automation ───────────────────────────────────────────────────────────────

model AutomationRule {
  id           String            @id @default(uuid())
  name         String
  description  String?
  isActive     Boolean           @default(true) @map("is_active")
  trigger      AutomationTrigger
  conditions   Json
  action       AutomationAction
  actionConfig Json              @map("action_config")
  lastRunAt    DateTime?         @map("last_run_at")
  createdById  String?           @map("created_by_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  createdBy User?           @relation("RuleCreatedBy", fields: [createdById], references: [id])
  logs      AutomationLog[]

  @@index([isActive])
  @@index([trigger])
  @@map("automation_rules")
}

model AutomationLog {
  id          String   @id @default(uuid())
  ruleId      String   @map("rule_id")
  outcome     String
  tasksCreated Int     @default(0) @map("tasks_created")
  details     Json?
  triggeredAt DateTime @default(now()) @map("triggered_at")

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([triggeredAt])
  @@map("automation_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String   // CREATE UPDATE DELETE IMPORT PLAN_CHANGE ROLE_CHANGE
  entity     String   // property lease tenant financial_record user
  entityId   String?  @map("entity_id")
  entityName String?  @map("entity_name")
  changes    Json?
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UsageRecord {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  type        UsageType
  periodStart DateTime  @map("period_start")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, periodStart])
  @@map("usage_records")
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @default("My Organization")
  industry  String?
  timezone  String   @default("UTC")
  currency  String   @default("USD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organization")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rules       Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  body      String
  type      String   @default("INFO")
  target    String   @default("ALL")
  active    Boolean  @default(true)
  startsAt  DateTime @default(now()) @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([active])
  @@map("announcements")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model ErrorLog {
  id        String   @id @default(uuid())
  method    String
  path      String
  status    Int
  message   String
  stack     String?
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("error_logs")
}
